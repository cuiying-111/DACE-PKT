def inject_pkt_plagiarism(
    code_data, qa_data, q_data, n_question,
    student_p=0.3, bias_p=0.3, seed=42
):
    """
    针对PKT任务的抄袭注入（同时修改代码和答案）

    参数：
        code_data: (N, T, D) 代码嵌入
        qa_data: (N, T) 题目ID + 答案
        q_data: (N, T) 题目ID
        n_question: 题目总数
        student_p: 选择多少比例的学生进行抄袭
        bias_p: 每个学生抄袭多少比例的题目
        seed: 随机种子

    返回：
        code_data_biased: 修改后的代码嵌入
        qa_data_biased: 修改后的答案
        plagiarism_mask: (N, T) 标记哪些位置被注入了抄袭
    """
    np.random.seed(seed)

    N, T, D = code_data.shape

    # 复制数据（避免修改原始数据）
    code_data_biased = code_data.copy()
    qa_data_biased = qa_data.copy()
    plagiarism_mask = np.zeros((N, T), dtype=bool)

    # 提取答案
    answers = (qa_data - q_data) // n_question

    # 计算每个学生的交互次数
    interactions_per_student = np.sum(q_data > 0, axis=1)

    # 选择要注入抄袭的学生（按交互次数降序）
    idxes = np.argsort(interactions_per_student)[::-1]
    num_students_to_bias = int(len(idxes) * student_p)
    selected_students = idxes[:num_students_to_bias]

    print(f"\n{'='*60}")
    print(f"PKT抄袭注入")
    print(f"{'='*60}")
    print(f"总学生数: {N}")
    print(f"选择 {num_students_to_bias} 个学生 ({student_p*100:.0f}%)")
    print(f"每个学生抄袭 {bias_p*100:.0f}% 的所有题目（不管答对答错）")

    total_plagiarized = 0

    # 对每个选中的学生进行抄袭注入
    for student_id in selected_students:
        # 找到这个学生所有有效的题目位置（不管答对答错）
        valid_positions = []
        for t in range(T):
            if q_data[student_id, t] == 0:  # padding
                continue
            valid_positions.append(t)

        if len(valid_positions) == 0:
            continue

        # 随机选择一部分题目进行抄袭（不管原来答对还是答错）
        num_to_plagiarize = int(len(valid_positions) * bias_p)
        if num_to_plagiarize == 0:
            num_to_plagiarize = 1

        plagiarize_positions = np.random.choice(
            valid_positions, size=min(num_to_plagiarize, len(valid_positions)), replace=False
        )

        # 对每个选中的位置，找到答对的学生并复制代码
        for t in plagiarize_positions:
            current_question = q_data[student_id, t]

            # 找到其他学生中，做同一题目且答对的学生
            potential_sources = []
            for other_student in range(N):
                if other_student == student_id:
                    continue
                for other_t in range(T):
                    if (q_data[other_student, other_t] == current_question and
                        answers[other_student, other_t] == 1):
                        potential_sources.append((other_student, other_t))
                        break  # 只需要一个

            if len(potential_sources) == 0:
                continue

            # 随机选择一个源
            source_student, source_t = potential_sources[
                np.random.randint(len(potential_sources))
            ]

            # ===== 关键：同时修改代码和答案 =====
            # 1. 复制代码嵌入
            code_data_biased[student_id, t, :] = code_data[source_student, source_t, :]

            # 2. 修改答案为正确
            qa_data_biased[student_id, t] = current_question + n_question

            # 3. 标记为抄袭
            plagiarism_mask[student_id, t] = True
            total_plagiarized += 1

    print(f"成功注入 {total_plagiarized} 个抄袭样本")
    print(f"抄袭比例: {total_plagiarized / (q_data > 0).sum() * 100:.2f}%")
    print(f"{'='*60}\n")

    return code_data_biased, qa_data_biased, plagiarism_mask


def select_bias(qa_array, num, bias_type="None", bias_p=0.0, select_pro=None):
    # 根据指定的异常行为类型（抄袭 / 瞎猜），对单个学生的作答序列进行噪声注入，修改部分作答结果为异常值。
    if bias_type == "plag":
        # 噪声类型：抄袭（模拟学生抄袭答案，强行把部分作答改成对）
        # 1. 随机选择要注入噪声的位置：从0~num-1中选 int(num*bias_p) 个索引
        select_idx = np.random.permutation(range(num))[0: int(num * bias_p)]
        qa_array[select_idx] = 1
    elif bias_type == "plag_by_pro":
        # 噪声类型：按题目抄袭（只对指定题目抄袭做对）
        # 1. 判断前num个作答中，哪些是指定题目（select_pro）的作答 2. 将这些题目的作答改为1（对），模拟抄袭特定题目的答案
        select_idx = torch.isin(qa_array[:num], torch.tensor(select_pro)).tolist()
        qa_array[:num][select_idx] = 1
    elif bias_type == "guess":
        # 噪声类型：瞎猜（模拟学生随机蒙答案，0/1随机）
        # 1. 随机选择要注入噪声的位置 2. 对选中位置随机赋值0或1（各50%概率），模拟瞎猜
        select_idx = np.random.permutation(range(num))[0: int(num * bias_p)]
        qa_array[select_idx] = torch.tensor(np.random.choice([0, 1], size=len(select_idx), p=[0.5, 0.5]))
    return qa_array


def inject_noise(qa_dataArray ,interactions_per_student, student_p, bias_p, bias_type, datasetname, return_noise_label=False):
    # 对整个数据集的学生作答序列进行批量噪声注入：
    # 筛选出要注入噪声的学生（按作答次数排序，通常选作答多的学生，更贴近真实场景）；
    # 对选中的学生，调用select_bias注入指定类型的噪声；
    # 可选返回 "噪声标签"（标记哪些学生被注入了噪声），用于后续评估。
    idxes = np.argsort(interactions_per_student)[::-1]
    # 1. 按学生的有效作答次数降序排序，返回排序后的索引
    num_of_studnet = len(qa_dataArray)
    #  2. 学生总数
    perm = idxes[0: int(num_of_studnet * student_p)]
    #  3. 选择前 int(num_of_studnet * student_p) 个学生（作答多的学生）进行噪声注入
    cnt = 0
    #  记录被注入噪声的学生数
    # import ipdb; ipdb.set_trace()
    if bias_type == 'plag_by_pro':
        # 加载题目信息文件（存储题目ID和频次/难度等）
        pro_cnt_path = f'data/{datasetname}/question.json'
        with open(pro_cnt_path, 'r') as f:
            pro_cnt = json.load(f)
            # 提取题目ID并按指定规则排序（如按频次降序），选前 int(bias_p*总数) 个题目作为抄袭目标
        pro_cnt_descending = [int(point['id']) + 1 for point in pro_cnt]
        select_pro = pro_cnt_descending[: int(len(pro_cnt_descending) * bias_p)]
    else:
        select_pro = None
    for i in range(num_of_studnet):
        qa_array = qa_dataArray[i] # 第i个学生的作答序列
        num = interactions_per_student[i] # 第i个学生的有效作答次数
        # data = [q_dataArray[i], qa_dataArray[i], p_dataArray[i], interactions_per_student[i]]
        if i in perm:# 该学生被选中注入噪声
            # import ipdb; ipdb.set_trace()
            # print(qa_dataArray[i][:])
            # 调用select_bias注入噪声，修改作答序列
            qa_dataArray[i][:] = select_bias(qa_array, num, bias_type, bias_p, select_pro)
            # print(qa_dataArray[i][:])
            cnt += 1  # 计数+1
    print("Injecting Over: " + str(cnt) + "Bad Seqs, " + str(num_of_studnet - cnt) + "Clean Seqs")
    if not return_noise_label:
        return qa_dataArray
    else:
        # 生成噪声标签：1表示该学生被注入噪声，0表示干净
        noise_label = np.zeros(num_of_studnet)
        noise_label[perm] = 1
        return qa_dataArray, noise_label


class PID_DATA(object):
    """
    原始 DACE PID_DATA
    修改：只使用CodeBERT，删除AST相关代码
    """

    def __init__(self, n_question, seqlen, dataset_name,
                 device="cuda", separate_char=",", base_cache_dir="./code_cache"):

        self.n_question = n_question
        self.seqlen = seqlen
        self.separate_char = separate_char
        self.dataset_name = dataset_name
        self.device = device

        # 只实例化CodeBERT编码器（删除AST编码器）
        self.code_embedder = CodeBERTEncoder(device=device)

        self.cache_dir = os.path.join(base_cache_dir, dataset_name)
        os.makedirs(self.cache_dir, exist_ok=True)

        # Batch code embedding
        # --------------------------------------------------

    def _encode_in_batches(self, code_list, lang_list, batch_size=2):
        """批量编码代码（只使用CodeBERT，删除AST参数）"""
        embeddings = []

        for i in tqdm(range(0, len(code_list), batch_size), desc="Encoding code"):
            batch_code = code_list[i: i + batch_size]
            batch_lang = lang_list[i: i + batch_size]

            batch_emb = []

            for code, lang in zip(batch_code, batch_lang):
                # ================================
                # 只使用CodeBERT编码（删除AST）
                # ================================
                with torch.no_grad():
                    emb = self.code_embedder(code, lang)

                # ================================
                # 立即移出GPU显存
                # ================================
                emb = emb.detach().cpu()

                batch_emb.append(emb.squeeze(0))

            batch_emb = torch.stack(batch_emb)

            # 已经在 CPU 上了，直接存
            embeddings.append(batch_emb)

            # ================================
            # 强制释放缓存池
            # ================================
            torch.cuda.empty_cache()

        return torch.cat(embeddings, dim=0)

        # --------------------------------------------------
        # Cache name (avoid experiment pollution)
        # --------------------------------------------------

    def _cache_path(self, cache_name):
        sig = "codebert_only_v1"  # 修改签名，避免与旧缓存冲突
        sig_hash = hashlib.md5(sig.encode()).hexdigest()[:8]
        return os.path.join(
            self.cache_dir,
            f"{cache_name}_code_{sig_hash}.npy"
        )

    def load_data(self, jsonl_path, cache_name="train", batch_size=2):
        """加载数据（只使用CodeBERT，兼容有/无AST的数据）"""
        cache_file = self._cache_path(cache_name)

        q_data, qa_data, p_data, code_data = [], [], [], []
        code_len_data = []  # mask (B, T)
        code_seq_len_data = []  # length (B,)

        all_code_texts = []
        all_code_langs = []
        user_records = []

        with open(jsonl_path, "r", encoding="utf-8") as f:
            for line in f:
                record = json.loads(line)
                pid_seq = record["pid_seq"]
                qid_seq = record["qid_seq"]
                a_seq = record["a_seq"]
                code_seq = record["code_seq"]
                lang_seq = record["lang_seq"]
                # 删除：ast_seq = record["ast_seq"]
                # 删除：ast_seq = [pad_ast(x, MAX_AST_PATHS) for x in ast_seq]

                assert len(pid_seq) == len(qid_seq) == len(a_seq) == len(code_seq) == len(lang_seq)
                user_records.append((pid_seq, qid_seq, a_seq, code_seq, lang_seq))
                all_code_texts.extend(code_seq)
                all_code_langs.extend(lang_seq)
                # 删除：all_ast_paths.extend(ast_seq)

        if os.path.exists(cache_file):
            print(f"Loading cached embeddings: {cache_file}")
            all_code_emb = torch.from_numpy(np.load(cache_file))
        else:
            print("Running CodeBERT batch encoding...")
            all_code_emb = self._encode_in_batches(
                all_code_texts,
                all_code_langs,
                batch_size=batch_size
            )
            np.save(cache_file, all_code_emb.numpy())

        idx = 0
        for pid_seq, qid_seq, a_seq, code_seq, lang_seq in user_records:
            seq_len = len(code_seq)
            n_split = math.ceil(seq_len / self.seqlen)

            for k in range(n_split):
                start = k * self.seqlen
                end = min((k + 1) * self.seqlen, seq_len)
                cur_len = end - start       # >>> ADD：真实长度

                qs, ps, qas, cs = [], [], [], []

                for i in range(start, end):
                    q = int(qid_seq[i])
                    p = int(pid_seq[i])
                    a = int(a_seq[i])
                    qa = q + a * self.n_question

                    qs.append(q)
                    ps.append(p)
                    qas.append(qa)
                    cs.append(all_code_emb[idx].numpy())
                    idx += 1

                pad_len = self.seqlen - cur_len
                if pad_len > 0:
                    qs.extend([0] * pad_len)
                    ps.extend([0] * pad_len)
                    qas.extend([0] * pad_len)
                    cs.extend(
                        [np.zeros(all_code_emb.shape[1])] * pad_len
                    )

                q_data.append(qs)
                p_data.append(ps)
                qa_data.append(qas)
                code_data.append(cs)
                # =========================
                # <<< MOD: 序列级 mask
                # =========================
                mask = [1] * cur_len + [0] * pad_len
                code_len_data.append(mask)
                code_seq_len_data.append(cur_len)  # 新加的一行

        q_array = np.array(q_data, dtype=np.int64)
        p_array = np.array(p_data, dtype=np.int64)
        qa_array = np.array(qa_data, dtype=np.int64)
        code_array = np.array(code_data, dtype=np.float32)
        code_len_array = np.array(code_len_data, dtype=np.int64)  # >>> ADD
        code_seq_len_array = np.array(code_seq_len_data, dtype=np.int64)

        return q_array, qa_array, p_array, code_array, code_len_array, code_seq_len_array
